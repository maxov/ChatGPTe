{
  "name": "chatgpte",
  "version": "1.0.0",
  "description": "Minimal Electron wrapper for ChatGPT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win --x64",
    "dist:linux": "electron-builder --linux --x64",
    "dist:all": "pnpm dist:mac && pnpm dist:win && pnpm dist:linux",
    "install-app": "rm -rf ~/Applications/ChatGPTe.app && cp -R dist/mac-arm64/ChatGPTe.app ~/Applications/"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "org.maxov.chatgpte",
    "productName": "ChatGPTe",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "toolbar.html",
      "preload-toolbar.js",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "icon": "icons",
      "category": "Network"
    }
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "electron-winstaller"
    ],
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
